# Force LF line endings for all text files
* text=auto eol=lf

# Explicitly declare text files
*.py    text eol=lf
*.sql   text eol=lf
*.md    text eol=lf
*.dax   text eol=lf
*.txt   text eol=lf
*.env*  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf

# Binary files — no diff, no line-ending conversion
*.xlsx  binary
*.csv   binary
*.pptx  binary
*.docx  binary
*.parquet binary
*.png   binary
*.jpg   binary
*.pdf   binary
